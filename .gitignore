# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Environments
# ".venv*/" (not ".venv/") so sibling environments such as .venv-ci/ are also
# ignored; previously they were excluded only by the virtualenv's own
# auto-generated nested .gitignore, which is not something to rely on.
.venv*/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Experiment outputs and trained models
artifacts/
runs/
*.joblib
*.ckpt

# The leaderboard's raw dump carries per-model wall-clock timings, so it is
# regenerated rather than committed. leaderboard.md and provenance.json are
# deterministic and ARE committed -- that is the reproducibility guarantee.
benchmarks/results/**/leaderboard.json

# Raw and processed corpora (acquire locally; see docs/datasets.md).
# Anchored to the repo root: an unanchored "data/" would also swallow the
# src/tulip/data package. "/data/*" (not "/data/") so the README negation
# works -- git never descends into a fully excluded directory.
/data/*
!/data/README.md

# Secrets — never commit environment or key material
.env
.env.*
*.pem
*.pfx
*.key
*.p12
secrets/

# Rendered docs site (regenerated by `mkdocs build`; the CI docs job builds it)
/site/

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
